# Copy to .env and fill in. Every value here is read by shared.config.Settings —
# components never read os.environ directly.

# --- Ingestion ---
# Comma-separated RSS feed URLs
NEWS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://www.aljazeera.com/xml/rss/all.xml

# --- Kafka / Redpanda (Day 2+) ---
KAFKA_BOOTSTRAP=localhost:19092
KAFKA_TOPIC=news.raw
PANDAPROXY_URL=http://localhost:8082
INGEST_API_KEY=change-me            # shared secret checked by Caddy in front of pandaproxy

# --- Storage (Day 2+) ---
DUCKDB_PATH=data/news.duckdb

# --- LLM providers (Day 4+) ---
GROQ_API_KEY=
GEMINI_API_KEY=
LLM_DAILY_CALL_BUDGET=500           # hard cap; busy news days degrade gracefully

# --- Observability (Day 4+) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=news-ai-platform

# --- Misc ---
LOG_LEVEL=INFO
