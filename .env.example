# Copy to .env and fill in. Every value here is read by shared.config.Settings —
# components never read os.environ directly.

# --- Ingestion ---
# Comma-separated RSS feed URLs
NEWS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://www.aljazeera.com/xml/rss/all.xml

# --- Kafka / Redpanda (Day 2+) ---
KAFKA_BOOTSTRAP=127.0.0.1:19092
KAFKA_TOPIC=news.raw
PANDAPROXY_URL=http://localhost:8082
# shared secret checked by Caddy in front of pandaproxy
INGEST_API_KEY=change-me

# --- Storage (Day 2+) ---
DUCKDB_PATH=data/news.duckdb

# --- Scheduler (Day 3+) ---
CYCLE_INTERVAL_S=300

# --- LLM providers (Day 4+) ---
GROQ_API_KEY=
GEMINI_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.5-flash
# gemini-2.5-flash free tier: 250/day; hard cap
LLM_DAILY_CALL_BUDGET=200
# bounds cycle time; backlog defers to next cycle
AI_MAX_PER_CYCLE=10
# gemini free tier is 5 RPM; ~4.6/min stays under
AI_CALL_INTERVAL_S=13

# --- Observability (Day 4+) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=news-ai-platform
# EU accounts: https://eu.api.smith.langchain.com
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Edge / deployment (Day 6+, EC2 only) ---
SITE_DOMAIN=example.duckdns.org
# from duckdns.org, used to point the domain at the EIP
DUCKDNS_TOKEN=
DASH_USER=admin
# generate: docker run --rm caddy:2 caddy hash-password --plaintext 'yourpass'
DASH_PASS_HASH=

# --- Misc ---
LOG_LEVEL=INFO
